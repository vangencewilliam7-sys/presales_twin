# ============================
# Presales Digital Twin — Environment Variables
# ============================
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# -- LLM (Required) --
OPENAI_API_KEY=sk-your-key-here
DEFAULT_MODEL=gpt-4o

# -- Supabase (Required) --
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Direct Postgres connection (for SQLAlchemy ORM)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# -- Deepgram — Module 2 (Required for audio transcription) --
DEEPGRAM_API_KEY=your-deepgram-key-here

# -- Web Search — Module 1 (Pick one) --
TAVILY_API_KEY=your-tavily-key-here
SERPAPI_KEY=your-serpapi-key-here
